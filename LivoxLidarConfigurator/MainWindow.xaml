<Window x:Class="LivoxLidarConfigurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Livox HAP LiDAR 配置器" Height="780" Width="1200" WindowStartupLocation="CenterScreen">

    <!-- 全局样式资源 -->
    <Window.Resources>
        <!-- 通用按钮样式 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="#FF2D7BBF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- 危险操作按钮样式 -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FFD9534F"/>
        </Style>
        <!-- 成功操作按钮样式 -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF5CB85C"/>
        </Style>
        <!-- 分组标题样式 -->
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF2D7BBF"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
        <!-- 标签样式 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- 输入框样式 -->
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- 状态指示灯样式 -->
        <Style x:Key="StatusIndicator" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Fill" Value="Gray"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- 顶部：初始化与发现 -->
            <RowDefinition Height="Auto"/>
            <!-- 中部：设备列表 + 设备信息 + 配置 -->
            <RowDefinition Height="*"/>
            <!-- 底部：日志与点云 -->
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- ==================== 第一行：初始化与发现 ==================== -->
        <GroupBox Grid.Row="0" Header="初始化与设备发现" Margin="0,0,0,6" Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 配置文件路径 -->
                <TextBlock Grid.Column="0" Text="配置文件：" Style="{StaticResource FieldLabel}"/>
                <TextBox Grid.Column="1" x:Name="TxtConfigFile" Text="hap_config.json" Style="{StaticResource FieldInput}" Margin="4,2"/>
                <Button Grid.Column="2" Content="浏览..." Click="BtnBrowseConfig_Click" Style="{StaticResource ActionButton}" Padding="8,4"/>

                <!-- 主机IP -->
                <TextBlock Grid.Column="3" Text="主机IP：" Style="{StaticResource FieldLabel}" Margin="12,2,4,2"/>
                <TextBox Grid.Column="4" x:Name="TxtHostIp" Text="192.168.1.50" Style="{StaticResource FieldInput}" Width="120"/>

                <!-- 初始化按钮 -->
                <Button Grid.Column="5" x:Name="BtnInitialize" Content="文件初始化" Click="BtnInitialize_Click" Style="{StaticResource ActionButton}" Margin="8,2"/>
                <!-- 直接初始化按钮 -->
                <Button Grid.Column="6" x:Name="BtnInitDirect" Content="直接初始化" Click="BtnInitDirect_Click" Style="{StaticResource SuccessButton}" Margin="4,2" ToolTip="不依赖配置文件，使用当前主机IP和默认端口直接初始化"/>
                <!-- 发现按钮 -->
                <Button Grid.Column="7" x:Name="BtnDiscover" Content="开始发现" Click="BtnDiscover_Click" Style="{StaticResource SuccessButton}" IsEnabled="False" Margin="4,2"/>
                <!-- 停止发现 -->
                <Button Grid.Column="8" x:Name="BtnStopDiscover" Content="停止发现" Click="BtnStopDiscover_Click" Style="{StaticResource DangerButton}" IsEnabled="False" Margin="4,2"/>
            </Grid>
        </GroupBox>

        <!-- ==================== 第二行：三列布局 ==================== -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <!-- 设备列表 -->
                <ColumnDefinition Width="280"/>
                <!-- 设备信息 -->
                <ColumnDefinition Width="300"/>
                <!-- 配置面板 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左列：设备列表 ===== -->
            <GroupBox Grid.Column="0" Header="已发现设备" Margin="0,0,4,0" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 设备列表 -->
                    <ListBox Grid.Row="0" x:Name="LstDevices" SelectionChanged="LstDevices_SelectionChanged"
                             FontFamily="Consolas" FontSize="11">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Ellipse Width="8" Height="8" Fill="{Binding ConnStatusColor}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 连接/断开 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="BtnConnect" Content="连接" Click="BtnConnect_Click" Style="{StaticResource SuccessButton}" IsEnabled="False" Padding="16,4"/>
                        <Button x:Name="BtnDisconnect" Content="断开" Click="BtnDisconnect_Click" Style="{StaticResource DangerButton}" IsEnabled="False" Padding="16,4"/>
                        <Ellipse x:Name="ConnIndicator" Style="{StaticResource StatusIndicator}"/>
                        <TextBlock x:Name="TxtConnStatus" Text="未连接" VerticalAlignment="Center" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- ===== 中列：设备信息 ===== -->
            <GroupBox Grid.Column="1" Header="设备信息" Margin="4,0,4,0" Padding="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PnlDeviceInfo" IsEnabled="False">
                        <!-- 基本信息 -->
                        <TextBlock Text="基本信息" Style="{StaticResource GroupHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="设备类型：" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtDeviceType" Style="{StaticResource FieldLabel}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="序列号：" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtSerialNumber" Style="{StaticResource FieldLabel}" FontFamily="Consolas"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="雷达IP：" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtLidarIp" Style="{StaticResource FieldLabel}" FontFamily="Consolas"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="命令端口：" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtCommandPort" Style="{StaticResource FieldLabel}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="发现时间：" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtDiscoveredTime" Style="{StaticResource FieldLabel}" FontSize="10"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="连接状态：" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtConnectedState" Style="{StaticResource FieldLabel}" FontWeight="Bold"/>
                        </Grid>

                        <Separator Margin="0,8"/>

                        <!-- 查询按钮组 -->
                        <TextBlock Text="信息查询" Style="{StaticResource GroupHeader}"/>
                        <WrapPanel>
                            <Button Content="查询固件类型" Click="BtnQueryFwType_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="查询固件版本" Click="BtnQueryFwVer_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="查询序列号" Click="BtnQuerySN_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="查询MAC地址" Click="BtnQueryMAC_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="查询工作状态" Click="BtnQueryWorkState_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="查询核心温度" Click="BtnQueryCoreTemp_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="查询状态码" Click="BtnQueryStatusCode_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                        </WrapPanel>

                        <Separator Margin="0,8"/>

                        <!-- 查询结果显示 -->
                        <TextBlock Text="查询结果" Style="{StaticResource GroupHeader}"/>
                        <TextBox x:Name="TxtQueryResult" IsReadOnly="True" TextWrapping="Wrap" 
                                 VerticalScrollBarVisibility="Auto" Height="120"
                                 FontFamily="Consolas" FontSize="11" Background="#FFF5F5F5"
                                 Padding="4"/>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>

            <!-- ===== 右列：配置面板 ===== -->
            <GroupBox Grid.Column="2" Header="设备配置" Margin="4,0,0,0" Padding="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PnlConfig" IsEnabled="False">

                        <!-- 扫描控制 -->
                        <TextBlock Text="扫描控制" Style="{StaticResource GroupHeader}"/>
                        <WrapPanel Margin="0,0,0,4">
                            <Button x:Name="BtnStartScan" Content="启动扫描" Click="BtnStartScan_Click" Style="{StaticResource SuccessButton}" Padding="12,4"/>
                            <Button x:Name="BtnStopScan" Content="停止扫描" Click="BtnStopScan_Click" Style="{StaticResource DangerButton}" Padding="12,4"/>
                            <Ellipse x:Name="ScanIndicator" Style="{StaticResource StatusIndicator}"/>
                            <TextBlock x:Name="TxtScanStatus" Text="未扫描" VerticalAlignment="Center" FontSize="11" Foreground="Gray"/>
                        </WrapPanel>

                        <Separator Margin="0,4"/>

                        <!-- 网络配置 -->
                        <TextBlock Text="网络配置" Style="{StaticResource GroupHeader}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="主机IP：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtCfgHostIp" Text="192.168.1.50" Style="{StaticResource FieldInput}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="命令端口：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtCfgCmdPort" Text="56000" Style="{StaticResource FieldInput}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="点云端口：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtCfgPointPort" Text="57000" Style="{StaticResource FieldInput}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="IMU端口：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtCfgImuPort" Text="58000" Style="{StaticResource FieldInput}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="推送端口：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtCfgPushPort" Text="55000" Style="{StaticResource FieldInput}"/>
                        </Grid>
                        <WrapPanel>
                            <Button Content="应用网络配置" Click="BtnApplyNetwork_Click" Style="{StaticResource ActionButton}"/>
                            <Button Content="使用配置文件" Click="BtnApplyConfigFile_Click" Style="{StaticResource ActionButton}"/>
                        </WrapPanel>

                        <Separator Margin="0,8"/>

                        <!-- 点云数据配置 -->
                        <TextBlock Text="点云数据配置" Style="{StaticResource GroupHeader}"/>
                        <StackPanel Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="点云数据类型：" Style="{StaticResource FieldLabel}" Width="100"/>
                                <ComboBox x:Name="CmbPclDataType" Width="160" SelectedIndex="1">
                                    <ComboBoxItem Content="IMU数据 (0)" Tag="0"/>
                                    <ComboBoxItem Content="笛卡尔高精度32位 (1)" Tag="1"/>
                                    <ComboBoxItem Content="笛卡尔低精度16位 (2)" Tag="2"/>
                                </ComboBox>
                                <Button Content="设置" Click="BtnSetPclDataType_Click" Style="{StaticResource ActionButton}" Padding="8,2"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="扫描模式：" Style="{StaticResource FieldLabel}" Width="100"/>
                                <ComboBox x:Name="CmbScanPattern" Width="160" SelectedIndex="0">
                                    <ComboBoxItem Content="非重复扫描 (0)" Tag="0"/>
                                    <ComboBoxItem Content="重复扫描 (1)" Tag="1"/>
                                    <ComboBoxItem Content="重复低帧率 (2)" Tag="2"/>
                                </ComboBox>
                                <Button Content="设置" Click="BtnSetScanPattern_Click" Style="{StaticResource ActionButton}" Padding="8,2"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="双发射模式：" Style="{StaticResource FieldLabel}" Width="100"/>
                                <CheckBox x:Name="ChkDualEmit" Content="启用双发射" VerticalAlignment="Center"/>
                                <Button Content="设置" Click="BtnSetDualEmit_Click" Style="{StaticResource ActionButton}" Padding="8,2"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,4"/>

                        <!-- IMU 控制 -->
                        <TextBlock Text="IMU 控制" Style="{StaticResource GroupHeader}"/>
                        <WrapPanel Margin="0,0,0,4">
                            <Button Content="启用IMU" Click="BtnEnableImu_Click" Style="{StaticResource ActionButton}" Padding="10,3" FontSize="11"/>
                            <Button Content="禁用IMU" Click="BtnDisableImu_Click" Style="{StaticResource ActionButton}" Padding="10,3" FontSize="11"/>
                        </WrapPanel>

                        <Separator Margin="0,4"/>

                        <!-- 安装姿态 -->
                        <TextBlock Text="安装姿态" Style="{StaticResource GroupHeader}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Roll：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtAttRoll" Text="0" Style="{StaticResource FieldInput}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Pitch：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="3" x:Name="TxtAttPitch" Text="0" Style="{StaticResource FieldInput}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Yaw：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtAttYaw" Text="0" Style="{StaticResource FieldInput}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="X(mm)：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="3" x:Name="TxtAttX" Text="0" Style="{StaticResource FieldInput}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Y(mm)：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtAttY" Text="0" Style="{StaticResource FieldInput}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Z(mm)：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="3" x:Name="TxtAttZ" Text="0" Style="{StaticResource FieldInput}"/>
                        </Grid>
                        <Button Content="设置安装姿态" Click="BtnSetAttitude_Click" Style="{StaticResource ActionButton}"/>

                        <Separator Margin="0,8"/>

                        <!-- FOV 配置 -->
                        <TextBlock Text="FOV 视场配置" Style="{StaticResource GroupHeader}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Yaw起始(0.01°)：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtFov0YawStart" Text="0" Style="{StaticResource FieldInput}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Yaw结束：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="3" x:Name="TxtFov0YawStop" Text="36000" Style="{StaticResource FieldInput}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Pitch起始：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtFov0PitchStart" Text="-700" Style="{StaticResource FieldInput}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Pitch结束：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="3" x:Name="TxtFov0PitchStop" Text="5500" Style="{StaticResource FieldInput}"/>
                        </Grid>
                        <WrapPanel>
                            <Button Content="设置FOV0" Click="BtnSetFov0_Click" Style="{StaticResource ActionButton}"/>
                            <Button Content="设置FOV1" Click="BtnSetFov1_Click" Style="{StaticResource ActionButton}"/>
                        </WrapPanel>

                        <Separator Margin="0,8"/>

                        <!-- 盲区设置 -->
                        <TextBlock Text="盲区设置" Style="{StaticResource GroupHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="盲区距离(cm)：" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtBlindSpot" Text="100" Style="{StaticResource FieldInput}" Width="60"/>
                            <TextBlock Text="(范围50-200)" Style="{StaticResource FieldLabel}" Foreground="Gray"/>
                            <Button Content="设置" Click="BtnSetBlindSpot_Click" Style="{StaticResource ActionButton}" Padding="8,2"/>
                        </StackPanel>

                        <Separator Margin="0,4"/>

                        <!-- 加热控制 -->
                        <TextBlock Text="加热控制" Style="{StaticResource GroupHeader}"/>
                        <WrapPanel Margin="0,0,0,4">
                            <Button Content="启用窗口加热" Click="BtnEnableGlassHeat_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="禁用窗口加热" Click="BtnDisableGlassHeat_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="启用强制加热" Click="BtnStartForceHeat_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                            <Button Content="停止强制加热" Click="BtnStopForceHeat_Click" Style="{StaticResource ActionButton}" Padding="8,3" FontSize="11"/>
                        </WrapPanel>

                        <Separator Margin="0,4"/>

                        <!-- 开机模式 -->
                        <TextBlock Text="开机工作模式" Style="{StaticResource GroupHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ComboBox x:Name="CmbBootMode" Width="150" SelectedIndex="0">
                                <ComboBoxItem Content="默认 (0)" Tag="0"/>
                                <ComboBoxItem Content="正常 (1)" Tag="1"/>
                                <ComboBoxItem Content="唤醒 (2)" Tag="2"/>
                            </ComboBox>
                            <Button Content="设置" Click="BtnSetBootMode_Click" Style="{StaticResource ActionButton}" Padding="8,2"/>
                        </StackPanel>

                        <Separator Margin="0,8"/>

                        <!-- 设备控制 -->
                        <TextBlock Text="设备控制" Style="{StaticResource GroupHeader}"/>
                        <WrapPanel>
                            <Button Content="重启设备" Click="BtnReboot_Click" Style="{StaticResource DangerButton}" Padding="12,4"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <!-- ==================== 第三行：日志 + 点云数据 ==================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 消息日志 -->
            <GroupBox Grid.Column="0" Header="消息日志" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11" Background="#FF1E1E1E" Foreground="#FFDCDCDC"
                             Padding="4"/>
                    <Button Grid.Row="1" Content="清空日志" Click="BtnClearLog_Click" 
                            Style="{StaticResource ActionButton}" HorizontalAlignment="Right" Padding="8,2" FontSize="11"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>

            <!-- 点云数据显示 -->
            <GroupBox Grid.Column="2" Header="点云数据" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" x:Name="TxtPointCloud" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11" Background="#FF1E1E1E" Foreground="#FF00FF00"
                             Padding="4"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtPclStats" Text="" VerticalAlignment="Center" FontSize="10" Foreground="Gray" Margin="4,0"/>
                        <Button Content="清空" Click="BtnClearPcl_Click" Style="{StaticResource ActionButton}" Padding="8,2" FontSize="11"/>
                        <CheckBox x:Name="ChkAutoScrollPcl" Content="自动滚动" IsChecked="True" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
                        <CheckBox x:Name="ChkShowPclData" Content="显示点云" IsChecked="True" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
